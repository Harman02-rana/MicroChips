FLASK_SECRET_KEY=change-this-secret
APP_ENV=development
PORT=5000
PUBLIC_BASE_URL=http://127.0.0.1:5000

# Supabase Auth
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_KEY=your-anon-key
# SUPABASE_ANON_KEY can be used instead of SUPABASE_KEY if your deployment uses that name.
# SUPABASE_ANON_KEY=your-anon-key
# Required for server-side creation/update of verified Auth users after email OTP.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Enable Google under Supabase Authentication > Providers, then allow:
# http://127.0.0.1:5000/auth/google/callback locally
# https://your-live-domain.com/auth/google/callback in production.

# Supabase PostgreSQL
SUPABASE_DB_HOST=aws-1-ap-south-1.pooler.supabase.com
SUPABASE_DB_PORT=6543
SUPABASE_DB_NAME=postgres
SUPABASE_DB_USER=postgres.ybbomppuyrucifdwgmpf
SUPABASE_DB_PASSWORD=your-real-supabase-db-password

# Alternative: set the full URL instead of the SUPABASE_DB_* fields.
# If your password has special characters, URL-encode it first.
# DATABASE_URL=postgresql://postgres.ybbomppuyrucifdwgmpf:your-url-encoded-password@aws-1-ap-south-1.pooler.supabase.com:6543/postgres?sslmode=require

ADMIN_EMAIL=admin@microchipcart.local
ADMIN_PASSWORD=Admin@12345
ADMIN_NOTIFICATION_EMAIL=admin@microchipcart.local
OWNER_EMAIL=owner@microchipcart.local
OWNER_PASSWORD=Owner@12345

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_TLS=true
SMTP_SSL=false
SMTP_USERNAME=yourgmail@gmail.com
SMTP_PASSWORD=your-16-character-gmail-app-password
COMPANY_EMAIL_SENDER=mcc_noreply@microchipcart.com
SMTP_FROM=mcc_noreply@microchipcart.com
SMTP_FROM_NAME=MicrochipCart
PRIVATE_SMTP_SENDERS=harmanrana709@gmail.com
SUPABASE_EMAIL_OTP_ENABLED=false

# Development only: shows a local 000000 OTP when neither Supabase Auth nor SMTP is configured.
# Keep this false when SMTP is configured or in production.
ALLOW_DEV_OTP_DISPLAY=false

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
